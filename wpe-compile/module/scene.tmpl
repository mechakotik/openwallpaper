{{define "scene"}}// autogenerated by wpe-compile

Shader shaders[] = {
    {{range $idx, $shader := .Shaders}}
        (Shader){
            .id = {{$idx}},
            .name = "{{$shader.Name}}",
            .vertex_shader = "{{$shader.VertexShader}}",
            .fragment_shader = "{{$shader.FragmentShader}}",
        },
    {{end}}
};

Scene scene = {
    .objects = (Object[]){
        {{range $idx, $obj := .Objects}}
            (Object){
                {{if eq (index $.Types $idx) 0}}
                    {{template "image_object" $obj}}
                {{else if eq (index $.Types $idx) 1}}
                    {{template "particle_object" $obj}}
                {{end}}
            },
        {{end}}
    },
    .general = {
        {{template "general" .General}}
    },
};

{{end}}

{{define "general"}}
.parallax = {{.Parallax}},
.parallax_amount = {{.ParallaxAmount}},
.parallax_delay = {{.ParallaxDelay}},
.parallax_mouse_influence = {{.ParallaxMouseInfluence}},
.shake = {{.Shake}},
.shake_amplitude = {{.ShakeAmplitude}},
.shake_roughness = {{.ShakeRoughness}},
.shake_speed = {{.ShakeSpeed}},
.ortho = {
    .w = {{.Ortho.Width}},
    .h = {{.Ortho.Height}},
},
.zoom = {{.Zoom}},
.fov = {{.FOV}},
.near_z = {{.NearZ}},
.far_z = {{.FarZ}},
{{end}}

{{define "image_object"}}
.id = {{.ID}},
.parent = {{.Parent}},
.name = "{{.Name}}",
.origin = {
    .x = {{index .Origin 0}},
    .y = {{index .Origin 1}},
    .z = {{index .Origin 2}},
},
.scale = {
    .x = {{index .Scale 0}},
    .y = {{index .Scale 1}},
    .z = {{index .Scale 2}},
},
.angles = {
    .x = {{index .Angles 0}},
    .y = {{index .Angles 1}},
    .z = {{index .Angles 2}},
},
.size = {
    .x = {{index .Size 0}},
    .y = {{index .Size 1}},
},
.perspective = {{.Perspective}},
.parallax_depth = {
    .x = {{index .ParallaxDepth 0}},
    .y = {{index .ParallaxDepth 1}},
},
.type = OBJECTTYPE_IMAGE,
.image = (ImageObject){
    .color = {
        .x = {{index .Color 0}},
        .y = {{index .Color 1}},
        .z = {{index .Color 2}},
    },
    .color_blend_mode = {{.ColorBlendMode}},
    .alpha = {{.Alpha}},
    .brightness = {{.Brightness}},
    .fullscreen = {{.Fullscreen}},
    .passthrough = {{.Config.Passthrough}},
    .material = (Material){
        {{template "material" .Material}}
    },
},
{{end}}

{{define "particle_object"}}
{{end}}

{{define "material"}}
.blending = "{{.Blending}}",
.shader_id = {{.CompiledShader}},
.texture_ids = (int[]){
    {{range $_, $tex := .ImportedTextures}}
        {{$tex}},
    {{end}}
},
.num_textures = {{len .Textures}},
{{end}}

